          }}
          onReviewAll={() => {
            setAutoReviewQids(session.questionQueue);
            setPostSectionScreen('review');
          }}
          onBack={() => navigate('/')}
        />
      );
    }
    
    // Use new LR Section Results for full-section mode
    if (session.mode === 'full-section') {
      return (
        <LRSectionResults
          session={session}
